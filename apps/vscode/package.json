{
  "name": "volo-vscode",
  "displayName": "Volo — Agent Trajectories",
  "description": "Inspect Volo agent recordings as trajectory views and replay them in one click.",
  "version": "0.1.0",
  "private": true,
  "publisher": "volo",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Visualization", "Testing"],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "test": "vitest run"
  },
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "volo.openTrajectory",
        "title": "Volo: Open Trajectory View"
      },
      {
        "command": "volo.replayRecording",
        "title": "Volo: Replay Recording (volo sim)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "volo.openTrajectory",
          "when": "resourceExtname == .json",
          "group": "volo"
        },
        {
          "command": "volo.replayRecording",
          "when": "resourceExtname == .json",
          "group": "volo"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
